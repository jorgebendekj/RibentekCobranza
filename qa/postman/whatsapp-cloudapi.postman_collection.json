{
  "info": {
    "name": "Aicobranzas - WhatsApp Cloud API QA",
    "_postman_id": "f72fd42b-6d4d-4e9f-88be-0d38d89fdb01",
    "description": "QA collection for WhatsApp Cloud API, window policy, templates, and tenant isolation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/health",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Webhook Verify - Valid Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/webhooks/meta?hub.mode=subscribe&hub.verify_token={{verify_token}}&hub.challenge={{challenge}}",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "webhooks",
            "meta"
          ],
          "query": [
            { "key": "hub.mode", "value": "subscribe" },
            { "key": "hub.verify_token", "value": "{{verify_token}}" },
            { "key": "hub.challenge", "value": "{{challenge}}" }
          ]
        }
      }
    },
    {
      "name": "Webhook Verify - Invalid Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/webhooks/meta?hub.mode=subscribe&hub.verify_token=wrong_token&hub.challenge=123",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "webhooks",
            "meta"
          ],
          "query": [
            { "key": "hub.mode", "value": "subscribe" },
            { "key": "hub.verify_token", "value": "wrong_token" },
            { "key": "hub.challenge", "value": "123" }
          ]
        }
      }
    },
    {
      "name": "Send Message - Positive",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"{{target_phone_number}}\",\n  \"message_text\": \"QA smoke test message\",\n  \"thread_id\": \"{{thread_id}}\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send"
          ]
        }
      }
    },
    {
      "name": "Send Message - Window Closed (Expected 409)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"{{target_phone_number_closed}}\",\n  \"message_text\": \"This should fail with WINDOW_CLOSED\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send"
          ]
        }
      }
    },
    {
      "name": "Send Template Message - Approved",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"{{target_phone_number_closed}}\",\n  \"template_id\": \"{{template_id}}\",\n  \"thread_id\": \"{{thread_id}}\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send-template",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send-template"
          ]
        }
      }
    },
    {
      "name": "Send Template Message - Not Approved (Expected 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"{{target_phone_number_closed}}\",\n  \"template_name\": \"{{template_name_not_approved}}\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send-template",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send-template"
          ]
        }
      }
    },
    {
      "name": "Send Message - Missing Phone Number",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_text\": \"No phone\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send"
          ]
        }
      }
    },
    {
      "name": "Tenant Isolation - Wrong Tenant Header",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id_wrong}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone_number\": \"{{target_phone_number}}\",\n  \"message_text\": \"Cross tenant validation test\"\n}"
        },
        "url": {
          "raw": "{{admin_base_url}}/api/meta/messages/send",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "messages",
            "send"
          ]
        }
      }
    },
    {
      "name": "Sync Meta Templates",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token}}" },
          { "key": "x-tenant-id", "value": "{{tenant_id}}" }
        ],
        "url": {
          "raw": "{{admin_base_url}}/api/meta/templates/sync?mode=pending",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "meta",
            "templates",
            "sync"
          ],
          "query": [
            { "key": "mode", "value": "pending" }
          ]
        }
      }
    }
  ],
  "event": []
}
