  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/health",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Webhook Verify - Valid Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/webhooks/meta?hub.mode=subscribe&hub.verify_token={{verify_token}}&hub.challenge={{challenge}}",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "webhooks",
            "meta"
          ],
          "query": [
            {
              "key": "hub.mode",
              "value": "subscribe"
            },
            {
              "key": "hub.verify_token",
              "value": "{{verify_token}}"
            },
            {
              "key": "hub.challenge",
              "value": "{{challenge}}"
            }
          ]
        }
      }
    },
    {
      "name": "Webhook Verify - Invalid Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{admin_base_url}}/webhooks/meta?hub.mode=subscribe&hub.verify_token=wrong_token&hub.challenge=123",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "webhooks",
            "meta"
          ],
          "query": [
            {
              "key": "hub.mode",
              "value": "subscribe"
            },
            {
              "key": "hub.verify_token",
              "value": "wrong_token"
            },
            {
              "key": "hub.challenge",
              "value": "123"
            }
          ]
        }
      }
    },
    {
      "name": "Send Message - Positive",
      "request": {
        "method": "POST",
        "header": [
